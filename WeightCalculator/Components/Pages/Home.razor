@page "/"

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-6">

    <!-- Title -->
    <MudText Typo="Typo.h4" Style="font-weight:800" Class="mb-4">Weight Calculator</MudText>

    <!-- Mode Toggle -->
    <MudToggleGroup T="Mode" @bind-Value="mode" Color="Color.Primary" Class="mb-4" Style="width:100%">
        <MudToggleItem Value="Mode.WorkingWeight">Working Weight</MudToggleItem>
        <MudToggleItem Value="Mode.OneRepMax">One Rep Max</MudToggleItem>
    </MudToggleGroup>

    <!-- Input Card -->
    <MudCard Elevation="4" Class="mb-4 rounded-xl">
        <MudCardContent Class="pa-6">

            <MudNumericField @bind-Value="rep"
                             Label="Reps"
                             Placeholder="e.g. 5"
                             Variant="Variant.Outlined"
                             Min="0"
                             Max="12"
                             Class="mb-4" />

            @if (mode == Mode.WorkingWeight)
            {
                <MudNumericField @bind-Value="oneRepMax"
                                 Label="One Rep Max"
                                 Placeholder="e.g. 550"
                                 Variant="Variant.Outlined"
                                 Class="mb-4" />
            }
            else
            {
                <MudNumericField @bind-Value="workingWeight"
                                 Label="Working Weight"
                                 Placeholder="e.g. 460"
                                 Variant="Variant.Outlined"
                                 Class="mb-4" />
            }

            @if (latestResult != null)
            {
                <MudAlert NoIcon="true"
                          Severity="Severity.Info"
                          Class="mb-2"
                          Style="font-weight:600; font-size:15px; border-radius:12px;">
                    @latestResult
                </MudAlert>
            }

        </MudCardContent>
        <MudCardActions Class="pa-4 pt-0">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Style="border-radius:12px; font-weight:700; font-size:16px;"
                       OnClick="Calculate">
                Calculate
            </MudButton>
        </MudCardActions>
    </MudCard>

    <!-- Calculation Log -->
    @if (calculationLog.Any())
    {
        <MudCard Elevation="2" Class="rounded-xl">
            <MudCardContent Class="pa-4">

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700; text-transform:uppercase; letter-spacing:1px;">
                        Calculation Log
                    </MudText>
                    <MudIconButton Icon="@(_expanded? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small"
                                   OnClick="OnExpandCollapseClick" />
                </MudStack>

                <MudDivider Class="mb-3" />

                <MudCollapse Expanded="_expanded">
                    <MudStack Spacing="2">
                        @foreach (var entry in calculationLog)
                        {
                            <MudPaper Elevation="0"
                                      Class="pa-3"
                                      Style="border-left: 3px solid var(--mud-palette-primary); border-radius: 4px; background: var(--mud-palette-background-grey);">
                                <MudText Typo="Typo.body2">@entry</MudText>
                            </MudPaper>
                        }
                    </MudStack>
                </MudCollapse>

            </MudCardContent>
        </MudCard>
    }

</MudContainer>

@code {
    private int? rep;
    private double? oneRepMax;
    private double? workingWeight;
    private string? latestResult;
    bool _expanded = true;

    private void OnExpandCollapseClick()
    {
        _expanded = !_expanded;
    }

    private enum Mode { WorkingWeight, OneRepMax }
    private Mode mode = Mode.WorkingWeight;
    private List<string> calculationLog = new();

    private void SetMode(Mode newMode)
    {
        mode = newMode;
        Clear();
    }

    private void Clear()
    {
        rep = null;
        oneRepMax = null;
        workingWeight = null;
    }

    private static readonly Dictionary<int, double> lowPercentageRepLookUp = new()
    {
        { 1, 95.5 }, { 2, 92.2 }, { 3, 89.2 }, { 4, 86.3 },
        { 5, 83.7 }, { 6, 81.1 }, { 7, 78.6 }, { 8, 76.2 },
        { 9, 73.9 }, { 10, 70.7 }, { 11, 68.0 }, { 12, 65.3 },
    };

    private static readonly Dictionary<int, double> highPercentageRepLookUp = new()
    {
        { 1, 100.0 }, { 2, 95.5 }, { 3, 92.2 }, { 4, 89.2 },
        { 5, 86.3 }, { 6, 83.7 }, { 7, 81.1 }, { 8, 78.6 },
        { 9, 76.2 }, { 10, 73.9 }, { 11, 70.7 }, { 12, 68.0 },
    };

    private void Calculate()
    {
        if (!rep.HasValue)
        {
            return;
        }

        if (!lowPercentageRepLookUp.TryGetValue(rep.Value, out var lowPercentage))
        {
            return;
        }
        if (!highPercentageRepLookUp.TryGetValue(rep.Value, out var highPercentage))
        {
            return;
        }

        if (mode == Mode.WorkingWeight && oneRepMax.HasValue)
        {
            var low = Math.Round((oneRepMax.Value * lowPercentage) / 100);
            var high = Math.Round((oneRepMax.Value * highPercentage) / 100);
            var message = $"Based on your inputs your working weight for your top set of {rep} reps should be between {low} and {high}";
            calculationLog.Insert(0, message);
            latestResult = message;
            Clear();
        }
        else if (mode == Mode.OneRepMax && workingWeight.HasValue)
        {
            var low = Math.Round(workingWeight.Value / (highPercentage / 100));
            var high = Math.Round(workingWeight.Value / (lowPercentage / 100));
            var message = $"Based on your inputs your 1RM should be between {low} and {high}";
            calculationLog.Insert(0, message);
            latestResult = message;
            Clear();
        }
    }
}